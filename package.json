{
  "name": "dmlink",
  "description": "Link your vercel project and domain in seconds",
  "version": "0.1.0",
  "author": "Crafter Station",
  "packageManager": "bun@1.3.13",
  "bin": {
    "dmlink": "bin/run.js"
  },
  "bugs": "https://github.com/crafter-station/dmlink/issues",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "fast-xml-parser": "^5.7.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "chai": "^4",
    "mocha": "^11",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "homepage": "https://github.com/crafter-station/dmlink",
  "keywords": [
    "dns",
    "domains",
    "vercel"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "dmlink",
    "dirname": "dmlink",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "topics": {
      "auth": {
        "description": "Manage authentication"
      },
      "domains": {
        "description": "Inspect DNS domains"
      },
      "projects": {
        "description": "Inspect Vercel projects"
      },
      "providers": {
        "description": "Manage DNS providers"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crafter-station/dmlink.git"
  },
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "check": "biome lint .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "bun run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
